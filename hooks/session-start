#!/usr/bin/env bash
# SessionStart hook for claude-session-manager plugin
# This runs synchronously — must be fast (~50ms target)

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source shared library
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

CWD="$(pwd)"

# Check if we're in a git repo; if not, exit silently with empty JSON
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  printf '{}\n'
  exit 0
fi

# Resolve repo slug from CWD
SLUG=$(resolve_slug "$CWD")
if [ -z "$SLUG" ]; then
  printf '{}\n'
  exit 0
fi

# Get git info
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || BRANCH="unknown"
COMMIT_HASH=$(git rev-parse --short HEAD 2>/dev/null) || COMMIT_HASH=""

# Generate session ID (16 hex chars, portable — no xxd dependency)
SESSION_ID=$(od -An -tx1 -N8 /dev/urandom | tr -d ' \n' | head -c 16)

# ISO timestamp
STARTED_AT=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Ensure session directory exists
REPOS_DIR="$SESSION_MANAGER_DIR/repos/$SLUG"
ensure_dir "$REPOS_DIR/sessions"
ensure_dir "$REPOS_DIR/briefings"
ensure_dir "$REPOS_DIR/projects"

# Look for active project BEFORE writing session file (so we can include projectSlug)
PROJECT_SLUG=$(get_active_project "$SLUG" "$BRANCH")
PROJECT_TITLE=""

if [ -n "$PROJECT_SLUG" ]; then
  PROJECT_FILE="$REPOS_DIR/projects/${PROJECT_SLUG}.json"
  PROJECT_TITLE=$(read_json_field "$PROJECT_FILE" "title")
  if [ -z "$PROJECT_TITLE" ]; then
    PROJECT_TITLE="$PROJECT_SLUG"
  fi
fi

# Write projectSlug as either "slug" or null
PROJECT_SLUG_JSON="null"
if [ -n "$PROJECT_SLUG" ]; then
  PROJECT_SLUG_JSON="\"$(escape_for_json "$PROJECT_SLUG")\""
fi

# Create session JSON (single write, no sed patching)
SESSION_FILE="$REPOS_DIR/sessions/${SESSION_ID}.json"
cat > "$SESSION_FILE" <<ENDJSON
{
  "sessionId": "${SESSION_ID}",
  "repoSlug": "$(escape_for_json "$SLUG")",
  "repoPath": "$(escape_for_json "$CWD")",
  "branch": "$(escape_for_json "$BRANCH")",
  "startedAt": "${STARTED_AT}",
  "endedAt": null,
  "startCommit": "${COMMIT_HASH}",
  "endCommit": null,
  "commitCount": 0,
  "projectSlug": ${PROJECT_SLUG_JSON},
  "notes": [],
  "tags": [],
  "summary": null,
  "planFile": null,
  "keyDecisions": []
}
ENDJSON

# Write current session marker so stop/end hooks can find it
printf '%s' "$SESSION_ID" > "$SESSION_MANAGER_DIR/.current-session-${SLUG}"

# Check for existing briefing
BRIEFING_PATH="$REPOS_DIR/briefings/latest.md"
HAS_BRIEFING=0
if [ -f "$BRIEFING_PATH" ]; then
  HAS_BRIEFING=1
fi

# Check for prior sessions on this branch (quick check: just see if any other session files exist)
HAS_PRIOR_SESSIONS=0
if [ -d "$REPOS_DIR/sessions" ]; then
  for sf in "$REPOS_DIR/sessions"/*.json; do
    [ -f "$sf" ] || continue
    [ "$sf" = "$SESSION_FILE" ] && continue
    # Quick grep for matching branch in the file
    if grep -q "\"branch\": \"$(escape_for_json "$BRANCH")\"" "$sf" 2>/dev/null; then
      HAS_PRIOR_SESSIONS=1
      break  # Found one, no need to scan more
    fi
  done
fi

# Build context message
CONTEXT=""

if [ "$HAS_BRIEFING" -eq 1 ] && [ -n "$PROJECT_SLUG" ]; then
  CONTEXT="You are resuming work on project '${PROJECT_TITLE}' in ${SLUG} on branch \`${BRANCH}\`. A resume briefing is available -- read it at \`${BRIEFING_PATH}\` for full context including progress, decisions, and next steps."
elif [ "$HAS_PRIOR_SESSIONS" -eq 1 ]; then
  CONTEXT="Prior sessions found for branch \`${BRANCH}\` in ${SLUG}. Run \`/claude-session-manager:resume\` for full context."
else
  CONTEXT="Session tracked for ${SLUG} on \`${BRANCH}\`."
fi

# Emit the context
emit_context "$CONTEXT"

exit 0
