#!/usr/bin/env bash
# SessionStart hook for claude-session-manager plugin
# This runs synchronously — must be fast (~50ms target)

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source shared library
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

CWD="$(pwd)"

# Check if we're in a git repo; if not, exit silently with empty JSON
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  printf '{}\n'
  exit 0
fi

# Resolve repo slug from CWD
SLUG=$(resolve_slug "$CWD")
if [ -z "$SLUG" ]; then
  printf '{}\n'
  exit 0
fi

# Get git info
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || BRANCH="unknown"
COMMIT_HASH=$(git rev-parse --short HEAD 2>/dev/null) || COMMIT_HASH=""

# Close any orphaned previous session (from /clear, /compact, or crash)
MARKER_FILE="$SESSION_MANAGER_DIR/.current-session-${SLUG}"
if [ -f "$MARKER_FILE" ]; then
  OLD_SESSION_ID=$(cat "$MARKER_FILE" 2>/dev/null)
  if [ -n "$OLD_SESSION_ID" ]; then
    OLD_SESSION_FILE="$REPOS_DIR/sessions/${OLD_SESSION_ID}.json"
    if [ -f "$OLD_SESSION_FILE" ]; then
      OLD_ENDED=$(read_json_field "$OLD_SESSION_FILE" "endedAt")
      if [ -z "$OLD_ENDED" ]; then
        ENDED_NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        sed "s/\"endedAt\": null/\"endedAt\": \"${ENDED_NOW}\", \"closedReason\": \"orphaned\"/" \
          "$OLD_SESSION_FILE" > "${OLD_SESSION_FILE}.tmp" && \
          mv "${OLD_SESSION_FILE}.tmp" "$OLD_SESSION_FILE"
      fi
    fi
  fi
fi

# Generate session ID (16 hex chars, portable — no xxd dependency)
SESSION_ID=$(od -An -tx1 -N8 /dev/urandom | tr -d ' \n' | head -c 16)

# ISO timestamp
STARTED_AT=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Ensure session directory exists
REPOS_DIR="$SESSION_MANAGER_DIR/repos/$SLUG"
ensure_dir "$REPOS_DIR/sessions"
ensure_dir "$REPOS_DIR/briefings"
ensure_dir "$REPOS_DIR/projects"

# Look for active project (for context message only — never auto-link)
PROJECT_SLUG=$(get_active_project "$SLUG" "$BRANCH")
PROJECT_TITLE=""

if [ -n "$PROJECT_SLUG" ]; then
  PROJECT_FILE="$REPOS_DIR/projects/${PROJECT_SLUG}.json"
  PROJECT_TITLE=$(read_json_field "$PROJECT_FILE" "title")
  if [ -z "$PROJECT_TITLE" ]; then
    PROJECT_TITLE="$PROJECT_SLUG"
  fi
fi

# Always write projectSlug as null — project linking is manual only
PROJECT_SLUG_JSON="null"

# Create session JSON (single write, no sed patching)
SESSION_FILE="$REPOS_DIR/sessions/${SESSION_ID}.json"
cat > "$SESSION_FILE" <<ENDJSON
{
  "schemaVersion": 1,
  "sessionId": "${SESSION_ID}",
  "repoSlug": "$(escape_for_json "$SLUG")",
  "repoPath": "$(escape_for_json "$CWD")",
  "branch": "$(escape_for_json "$BRANCH")",
  "startedAt": "${STARTED_AT}",
  "endedAt": null,
  "startCommit": "${COMMIT_HASH}",
  "endCommit": null,
  "commitCount": 0,
  "projectSlug": ${PROJECT_SLUG_JSON},
  "notes": [],
  "tags": [],
  "summary": null,
  "planFile": null,
  "keyDecisions": []
}
ENDJSON

# Write current session marker so stop/end hooks can find it
printf '%s' "$SESSION_ID" > "$SESSION_MANAGER_DIR/.current-session-${SLUG}"

# Read resume mode from config (default: "ask")
RESUME_MODE=$(read_json_field "$CONFIG_FILE" "resumeMode")
RESUME_MODE="${RESUME_MODE:-ask}"

# Check for existing briefing
BRIEFING_PATH="$REPOS_DIR/briefings/latest.md"
HAS_BRIEFING=0
if [ -f "$BRIEFING_PATH" ]; then
  HAS_BRIEFING=1
fi

# Check for prior sessions on this branch (quick check)
HAS_PRIOR_SESSIONS=0
if [ -d "$REPOS_DIR/sessions" ]; then
  for sf in "$REPOS_DIR/sessions"/*.json; do
    [ -f "$sf" ] || continue
    [ "$sf" = "$SESSION_FILE" ] && continue
    if grep -q "\"branch\": \"$(escape_for_json "$BRANCH")\"" "$sf" 2>/dev/null; then
      HAS_PRIOR_SESSIONS=1
      break
    fi
  done
fi

# Build context message based on resume mode
CONTEXT=""

if [ "$RESUME_MODE" = "manual" ]; then
  # Manual mode: only confirm tracking, never mention prior work
  CONTEXT="Session tracked for ${SLUG} on \`${BRANCH}\`."

elif [ "$RESUME_MODE" = "auto" ]; then
  # Auto mode: tell Claude to read the full briefing immediately
  if [ "$HAS_BRIEFING" -eq 1 ] && [ "$HAS_PRIOR_SESSIONS" -eq 1 ]; then
    CONTEXT="Prior sessions found for branch \`${BRANCH}\` in ${SLUG}. A resume briefing is available -- read it at \`${BRIEFING_PATH}\` for full context including progress, decisions, and next steps."
    if [ -n "$PROJECT_SLUG" ]; then
      CONTEXT="${CONTEXT}
Active project: '${PROJECT_TITLE}'. To attach this session, run \`/claude-session-manager:start-project\`."
    fi
  elif [ "$HAS_PRIOR_SESSIONS" -eq 1 ]; then
    CONTEXT="Prior sessions found for branch \`${BRANCH}\` in ${SLUG}. Run \`/claude-session-manager:resume\` for full context."
  else
    CONTEXT="Session tracked for ${SLUG} on \`${BRANCH}\`."
  fi

else
  # Ask mode (default): inject a summary snippet, let Claude ask the user
  if [ "$HAS_PRIOR_SESSIONS" -eq 1 ] || [ -n "$PROJECT_SLUG" ]; then
    # Gather mini-summary for the ask prompt
    SESSION_COUNT=$(get_session_count "$SLUG" "$BRANCH")
    LATEST_INFO=$(get_latest_session_info "$SLUG" "$BRANCH" "$SESSION_FILE")
    LAST_SUMMARY=""
    LAST_TIME_AGO="unknown"

    if [ -n "$LATEST_INFO" ]; then
      LAST_SUMMARY="${LATEST_INFO%%|*}"
      LAST_STARTED="${LATEST_INFO##*|}"
      if [ -n "$LAST_STARTED" ]; then
        LAST_TIME_AGO=$(time_ago "$LAST_STARTED")
      fi
    fi

    # Build the project line
    PROJECT_LINE=""
    if [ -n "$PROJECT_SLUG" ]; then
      PROJECT_LINE="- Project: \"${PROJECT_TITLE}\" (active, not yet linked — run \`/claude-session-manager:start-project\` to attach)"
    fi

    # Build activity line
    ACTIVITY_LINE=""
    if [ -n "$LAST_SUMMARY" ]; then
      ACTIVITY_LINE="- Last activity: \"${LAST_SUMMARY}\""
    fi

    CONTEXT="[claude-session-manager] Prior work detected on this branch:
${PROJECT_LINE}
- Branch: ${BRANCH}
- Last session: ${LAST_TIME_AGO} (${SESSION_COUNT} total sessions on this branch)
${ACTIVITY_LINE}

Ask the user if they want to resume this work before proceeding.
If they want to resume, read the full briefing at \`${BRIEFING_PATH}\`.
If they want to start fresh, proceed with their request normally.
Do not auto-load the briefing without asking."
  else
    CONTEXT="Session tracked for ${SLUG} on \`${BRANCH}\`."
  fi
fi

# Emit the context
emit_context "$CONTEXT"

exit 0
